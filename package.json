{
  "name": "geom-playground",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Paste WKT, WKB, EsriJSON, or GeoJSON geometries — visualize, edit, and convert them client-side",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@terraformer/arcgis": "^2.1.2",
