    "geos-wasm": "^3.1.0",
    "lucide-react": "^0.468.0",
    "maplibre-gl": "^4.0.0",
    "monaco-editor": "^0.55.1",
    "proj4": "^2.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/geojson": "^7946.0.0",
    "@types/node": "^25.5.0",
    "@types/proj4": "^2.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
